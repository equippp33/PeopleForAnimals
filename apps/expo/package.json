{
  "name": "@acme/expo",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo  node_modules",
    "dev": "dotenv -e ../../.env -- expo start -c",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "build": "cross-env NODE_ENV=production dotenv -e ../../.env -- eas build -p android --profile production --clear-cache",
    "prebuild": "expo prebuild && npm run tailwind:build",
    "build:apk:development": "cross-env NODE_ENV=development dotenv -e ../../.env -- eas build -p android --profile development",
    "build:ios:development": "cross-env NODE_ENV=development dotenv -e ../../.env -- eas build -p ios --profile development ",
    "build:ios:simulator": "cross-env NODE_ENV=development dotenv -e ../../.env -- eas build -p ios --profile development-simulator ",
    "build:ios": "cross-env NODE_ENV=production dotenv -e ../../.env -- eas build -p ios --profile preview ",
    "build:apk": "cross-env NODE_ENV=production dotenv -e ../../.env -- eas build -p android --profile preview ",
    "build:apk:production": "cross-env NODE_ENV=production dotenv -e ../../.env -- eas build -p android --profile production",
    "build:ios:production": "cross-env NODE_ENV=production dotenv -e ../../.env -- eas build -p ios --profile production",
    "build:local": "cross-env NODE_ENV=production dotenv -e ../../.env -- expo export --platform android",
    "build:local:ios": "cross-env NODE_ENV=production dotenv -e ../../.env -- expo export --platform ios",
    "run:android": "dotenv -e ../../.env -- expo run:android",
    "run:ios": "dotenv -e ../../.env -- expo run:ios",
    "export": "expo export",
    "eas-build-post-install": "tailwindcss -i ./src/styles.css -o ./node_modules/.cache/nativewind/styles.css.native.css && tailwindcss -i ./src/styles.css -o ./node_modules/.cache/nativewind/styles.css.ios.css",
    "tailwind:build": "tailwindcss -i ./src/styles.css -o ./src/styles.output.css"
  },
  "dependencies": {
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@expo-google-fonts/dm-sans": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.50.0",
    "@trpc/client": "^11.0.0-rc.446",
    "@trpc/react-query": "^11.0.0-rc.446",
    "@trpc/server": "^11.0.0-rc.446",
    "@trpc/tanstack-react-query": "^11.0.0-rc.446",
    "expo": "~54.0.22",
    "expo-build-properties": "^1.0.9",
    "expo-camera": "^17.0.9",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.16",
    "expo-file-system": "^19.0.17",
    "expo-font": "^14.0.9",
    "expo-image-manipulator": "^14.0.7",
    "expo-image-picker": "^17.0.8",
    "expo-intent-launcher": "^13.0.7",
    "expo-linear-gradient": "15.0.7",
    "expo-linking": "~8.0.8",
    "expo-location": "^19.0.7",
    "expo-media-library": "^18.2.1",
    "expo-router": "~6.0.14",
    "expo-secure-store": "^15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "^15.0.9",
    "native": "link:@acme/tailwind-config/native",
    "nativewind": "~4.1.23",
    "postgres": "^3.4.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-otp-entry": "^1.8.5",
    "react-native-reanimated": "~4.1.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-toast-message": "^2.3.2",
    "setimmediate": "^1.0.5",
    "superjson": "2.2.2",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@acme/api": "workspace:*",
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@babel/core": "^7.26.10",
    "@types/react": "19.1.17",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "metro": "0.83.3",
    "metro-cache": "0.80.9",
    "metro-config": "0.80.9",
    "metro-resolver": "0.80.9",
    "metro-runtime": "0.80.9",
    "prettier": "catalog:",
    "typescript": "^5.9.3"
  },
  "prettier": "@acme/prettier-config"
}
